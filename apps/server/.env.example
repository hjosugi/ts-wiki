# Server port
PORT=4000

# Database backend. sqlite is the local default; libsql supports local libSQL
# files and Turso through an embedded replica.
DATABASE_DRIVER=sqlite

# SQLite database file (created on first run when DATABASE_DRIVER=sqlite)
DATABASE_PATH=./data/ts-wiki.sqlite

# SQLite FTS5 tokenizer. Keep unicode61 for English/European prose. Use trigram
# before first migration for Japanese/Chinese/Korean search. Existing DBs can be
# rebuilt from Admin -> Search index, or with db:reindex-search after a backup.
TS_WIKI_FTS_TOKENIZER=unicode61

# Turso/libSQL target.
# DATABASE_DRIVER=libsql
# LIBSQL_URL=libsql://your-database.turso.io
# LIBSQL_AUTH_TOKEN=your-turso-token
# Optional for remote LIBSQL_URL. Defaults to DATA_DIR/ts-wiki-libsql-replica.db.
# LIBSQL_REPLICA_PATH=./data/ts-wiki-libsql-replica.db

# Directory for runtime data (uploaded assets, etc.)
DATA_DIR=./data

# Built web app directory served under /ui and used for SPA fallback routes.
# WEB_DIST_DIR=../web/dist

# Secret used to sign auth tokens — CHANGE THIS in production.
JWT_SECRET=dev-insecure-secret-change-me
# JWT lifetime in seconds. Default: 30 days.
# TS_WIKI_JWT_TTL_SECONDS=2592000

# Private wiki mode requires login for page/search/realtime read routes.
# Registration off still allows first-admin bootstrap when the database is empty.
# TS_WIKI_PRIVATE=false
# TS_WIKI_REGISTRATION=open

# Public origin used for passkeys/WebAuthn verification and OIDC redirects.
# Set this to the HTTPS URL users open in production.
# TS_WIKI_PUBLIC_ORIGIN=https://wiki.example.com
TS_WIKI_SITE_NAME=ts-wiki
# Defaults to the hostname in TS_WIKI_PUBLIC_ORIGIN. For localhost dev, use localhost.
# PASSKEY_RP_ID=wiki.example.com

# Optional generic OIDC provider.
# OIDC_ENABLED=false
# OIDC_PROVIDER_ID=oidc
# OIDC_PROVIDER_LABEL=OIDC
# OIDC_ISSUER=https://accounts.example.com
# OIDC_CLIENT_ID=client-id
# OIDC_CLIENT_SECRET=client-secret
# OIDC_REDIRECT_URI=https://wiki.example.com/api/auth/oidc/oidc/callback
# OIDC_SCOPES=openid,email,profile
# OIDC_ALLOW_REGISTRATION=true
# OIDC_EMAIL_DOMAINS=example.com
# OIDC_DEFAULT_ROLE=viewer
#
# Multiple OIDC providers can use numbered OIDC_N_* prefixes:
# OIDC_1_PROVIDER_ID=google
# OIDC_1_PROVIDER_LABEL=Google
# OIDC_1_ISSUER=https://accounts.google.com
# OIDC_1_CLIENT_ID=google-client-id
# OIDC_1_CLIENT_SECRET=google-client-secret
# OIDC_1_REDIRECT_URI=https://wiki.example.com/api/auth/oidc/google/callback
# OIDC_2_PROVIDER_ID=okta
# OIDC_2_PROVIDER_LABEL=Okta
# OIDC_2_ISSUER=https://okta.example.com/oauth2/default
# OIDC_2_CLIENT_ID=okta-client-id
# OIDC_2_CLIENT_SECRET=okta-client-secret
# OIDC_2_REDIRECT_URI=https://wiki.example.com/api/auth/oidc/okta/callback
#
# Or configure an array as JSON.
# TS_WIKI_OIDC_PROVIDERS=[{"id":"google","label":"Google","issuer":"https://accounts.google.com","clientId":"google-client-id","clientSecret":"google-client-secret","redirectUri":"https://wiki.example.com/api/auth/oidc/google/callback"}]

# Site date defaults. Admins can change these later in Admin -> Appearance.
# TS_WIKI_DEFAULT_LOCALE=en
# TS_WIKI_TIMEZONE=UTC
# TS_WIKI_DATE_FORMAT=medium

# Optional asset storage. local stores bytes under DATA_DIR/assets.
# Upload limit in bytes. Default: 25 MiB.
# ASSET_MAX_BYTES=26214400
# ASSET_STORAGE=local
# ASSET_PUBLIC_BASE_URL=
# ASSET_STORAGE=r2
# ASSET_PUBLIC_BASE_URL=https://cdn.example.com/assets
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# R2_BUCKET=ts-wiki-assets
# R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# Trust X-Forwarded-For / CF-Connecting-IP headers only when ts-wiki is
# reachable exclusively through a trusted reverse proxy.
# TS_WIKI_TRUST_PROXY_HEADERS=false

# Webhook delivery policy. Defaults: 3 attempts; 1m,2m,4m,8m,15m backoff;
# 2000 response bytes; 1000 error bytes.
# TS_WIKI_WEBHOOK_MAX_ATTEMPTS=3
# TS_WIKI_WEBHOOK_BACKOFF_MS=60000,120000,240000,480000,900000
# TS_WIKI_WEBHOOK_MAX_RESPONSE_BYTES=2000
# TS_WIKI_WEBHOOK_MAX_ERROR_BYTES=1000

# Optional password for the admin user created by db:seed.
# If omitted, db:seed generates and prints a one-time random password.
# TS_WIKI_SEED_ADMIN_PASSWORD=change-me-before-seeding

# Comma-separated CORS origin allow-list. Omit for permissive local/dev CORS.
# In production, omitted means same-origin only.
# TS_WIKI_CORS_ORIGINS=http://localhost:5173,https://wiki.example.com

# ── Realtime event bus ─────────────────────────────────────────────────────
# db = multi-instance: page-change events are written to SQLite and polled by
# every server process sharing the same DATABASE_PATH. memory = single process.
TS_WIKI_EVENT_BUS=db
# Optional stable label for logs/diagnostics; random by default.
# TS_WIKI_INSTANCE_ID=ts-wiki-1
TS_WIKI_EVENT_POLL_MS=250

# ── Git storage (optional; mirrors pages to a Git repo, like Wiki.js) ────────
# When enabled, every page change writes a Markdown file + commit (DB → Git),
# and POST /api/git/sync imports external commits (Git → DB).
# (Namespaced TS_WIKI_GIT_* on purpose — plain GIT_DIR/GIT_AUTHOR_* are reserved by Git.)
TS_WIKI_GIT_ENABLED=false
# Repo working directory (defaults to <DATA_DIR>/repo).
# TS_WIKI_GIT_DIR=./data/repo
TS_WIKI_GIT_BRANCH=main
# Optional remote. When set, sync() pulls external commits then pushes local ones.
# TS_WIKI_GIT_REMOTE=origin
TS_WIKI_GIT_AUTHOR_NAME=ts-wiki
TS_WIKI_GIT_AUTHOR_EMAIL=ts-wiki@localhost
# Background auto-sync interval in ms (pull→import→push). 0 = off (manual /api/git/sync only).
TS_WIKI_GIT_SYNC_INTERVAL_MS=0
