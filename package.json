{
  "name": "kawaii-wiki.ts",
  "version": "1.0.32",
  "packageManager": "bun@1.3.14",
  "license": "0BSD",
  "private": true,
  "type": "module",
  "description": "A modern, lean, FP-leaning open-source wiki. Bun + Elysia + Drizzle (SQLite/FTS5) + Vue 3.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "esbuild": "0.25.12",
    "vite": "8.1.4"
  },
  "scripts": {
    "dev": "bun --filter '@kawaii-wiki/server' --filter '@kawaii-wiki/web' dev",
    "dev:server": "bun --filter '@kawaii-wiki/server' dev",
    "dev:web": "bun --filter '@kawaii-wiki/web' dev",
    "build": "bun --filter '@kawaii-wiki/web' build && bun scripts/check-bundle-size.ts",
    "lint": "oxlint apps packages scripts e2e playwright.config.ts",
    "db:migrate": "bun --filter '@kawaii-wiki/server' db:migrate",
    "db:migrate-to": "bun --filter '@kawaii-wiki/server' db:migrate-to",
    "db:reindex-search": "bun --filter '@kawaii-wiki/server' db:reindex-search",
    "db:seed": "bun --filter '@kawaii-wiki/server' db:seed",
    "docs:install": "bun --filter '@kawaii-wiki/server' docs:install",
    "db:reset": "bun --filter '@kawaii-wiki/server' db:reset",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test packages apps/server && bun --filter '@kawaii-wiki/web' test",
    "test:e2e": "playwright test",
    "version:bump": "bun scripts/bump-version.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "oxlint": "1.74.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.14"
  }
}
