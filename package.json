{
  "name": "ts-wiki",
  "version": "0.4.0",
  "license": "0BSD",
  "private": true,
  "type": "module",
  "description": "A modern, lean, FP-leaning open-source wiki. Bun + Elysia + Drizzle (SQLite/FTS5) + Vue 3.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --filter '@ts-wiki/server' --filter '@ts-wiki/web' dev",
    "dev:server": "bun --filter '@ts-wiki/server' dev",
    "dev:web": "bun --filter '@ts-wiki/web' dev",
    "build": "bun --filter '@ts-wiki/web' build",
    "db:migrate": "bun --filter '@ts-wiki/server' db:migrate",
    "db:reindex-search": "bun --filter '@ts-wiki/server' db:reindex-search",
    "db:seed": "bun --filter '@ts-wiki/server' db:seed",
    "db:reset": "bun --filter '@ts-wiki/server' db:reset",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test packages apps/server && bun --filter '@ts-wiki/web' test"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
